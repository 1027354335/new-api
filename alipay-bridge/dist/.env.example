# Copy this file to .env on the domestic server and fill in real values.
# Existing system environment variables take priority over values in .env.

# HTTP listen address for this bridge service.
ALIPAY_BRIDGE_LISTEN_ADDR=:3001

# Alipay domestic merchant credentials.
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_SANDBOX=false

# Public base URL of this domestic bridge service.
# Configure this domain in Alipay callback settings if needed.
ALIPAY_BRIDGE_PUBLIC_BASE_URL=https://pay-cn.example.com

# Overseas main server settlement endpoint.
ALIPAY_BRIDGE_OVERSEAS_SETTLE_URL=https://main.example.com/api/alipay/bridge/settle

# Must be exactly the same value as AlipayBridgeSecret on the overseas main server.
# Use a long random value, for example: openssl rand -hex 32
ALIPAY_BRIDGE_SECRET=

# Browser redirect targets after synchronous Alipay return.
ALIPAY_BRIDGE_RETURN_SUCCESS_URL=https://main.example.com/console/topup?pay=success
ALIPAY_BRIDGE_RETURN_FAIL_URL=https://main.example.com/console/topup?pay=fail
